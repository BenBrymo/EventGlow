rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.role == "admin";
    }

    match /users/{userId} {
      allow create: if isOwner(userId) &&
        (
          !request.resource.data.keys().hasAny(['role']) ||
          request.resource.data.role == "user"
        );
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) &&
        !request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasAny(['role', 'isAdmin', 'emailVerified', 'uid', 'createdAtMs']);
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /eventCategories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /boughtTickets/{ticketId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (
          resource.data.userId is string &&
          resource.data.userId == request.auth.uid
        )
      );
      allow create: if signedIn() && (
        request.resource.data.userId is string &&
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if false;
    }

    // Client-assisted rate limit state.
    // Only owner/admin can read and only owner can write.
    // Keep minimal write surface by allowing only merge updates from owner app flow.
    match /rate_limits/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        (
          request.auth.token.email != null &&
          resource.data.customerEmail == request.auth.token.email
        )
      );

      allow create: if signedIn() && (
        (
          request.resource.data.userId is string &&
          request.resource.data.userId == request.auth.uid
        ) ||
        (
          request.auth.token.email != null &&
          request.resource.data.customerEmail is string &&
          request.resource.data.customerEmail == request.auth.token.email
        )
      );

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
